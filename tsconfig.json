{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"allowJs": true,
		"target": "ES2023",
		"module": "ESNext",
		"sourceMap": true,
		"strict": true,
		"alwaysStrict": true,
		"strictNullChecks": true,
		"moduleResolution": "Bundler",
		"moduleDetection": "force",
		"lib": ["ESNext", "DOM"]
	},
	"include": ["./src/**/*.ts"]
}
