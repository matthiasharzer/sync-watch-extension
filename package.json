{
	"name": "sync-watch-extension",
	"version": "1.0.0",
	"scripts": {
		"build": "esbuild --bundle --outdir=public/dist --keep-names --define:__DEBUG__=false src/*.ts",
		"build:dev": "esbuild --bundle --outdir=public/dist --keep-names --sourcemap --define:__DEBUG__=true src/*.ts",
		"watch": "esbuild --bundle --outdir=public/dist --keep-names --sourcemap --watch --define:__DEBUG__=true src/*.ts",
		"format": "biome check --write",
		"typecheck": "tsc --noEmit",
		"analyze": "biome check --error-on-warnings"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/chrome": "0.1.40",
		"esbuild": "0.28.0",
		"typescript": "6.0.2"
	}
}
